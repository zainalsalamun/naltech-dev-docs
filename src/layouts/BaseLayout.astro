---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal developer documentation hub" } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="read-progress" id="readProgress"></div>
    <button class="mobile-menu-button" id="mobileMenuButton" type="button" aria-label="Buka navigasi">
      ☰
    </button>
    <slot />
    <button class="back-top" id="backTop" type="button" aria-label="Kembali ke atas">↑</button>
    <script>
      const progress = document.getElementById("readProgress");
      const backTop = document.getElementById("backTop");
      const menuButton = document.getElementById("mobileMenuButton");
      const sidebar = document.getElementById("docsSidebar");
      const mainScroller = document.querySelector(".docs-main");
      const lockedScrollers = [sidebar, mainScroller].filter(Boolean);

      function lockOverscroll(scroller) {
        let touchStartY = 0;

        function shouldBlock(deltaY) {
          const atTop = scroller.scrollTop <= 0;
          const atBottom = Math.ceil(scroller.scrollTop + scroller.clientHeight) >= scroller.scrollHeight;
          return (atTop && deltaY < 0) || (atBottom && deltaY > 0);
        }

        scroller.addEventListener("wheel", (event) => {
          if (shouldBlock(event.deltaY)) event.preventDefault();
        }, { passive: false });

        scroller.addEventListener("touchstart", (event) => {
          touchStartY = event.touches[0]?.clientY ?? 0;
        }, { passive: true });

        scroller.addEventListener("touchmove", (event) => {
          const currentY = event.touches[0]?.clientY ?? touchStartY;
          const deltaY = touchStartY - currentY;
          if (shouldBlock(deltaY)) event.preventDefault();
        }, { passive: false });
      }

      lockedScrollers.forEach(lockOverscroll);

      function updateReadingProgress() {
        const scrollTop = mainScroller ? mainScroller.scrollTop : window.scrollY;
        const scrollHeight = mainScroller ? mainScroller.scrollHeight : document.documentElement.scrollHeight;
        const viewportHeight = mainScroller ? mainScroller.clientHeight : window.innerHeight;
        const max = scrollHeight - viewportHeight;
        const value = max > 0 ? (scrollTop / max) * 100 : 0;
        if (progress) progress.style.width = `${value}%`;
        backTop?.classList.toggle("is-visible", scrollTop > 520);
      }

      (mainScroller ?? window).addEventListener("scroll", updateReadingProgress, { passive: true });
      updateReadingProgress();

      backTop?.addEventListener("click", () => {
        if (mainScroller) {
          mainScroller.scrollTo({ top: 0, behavior: "smooth" });
          return;
        }

        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      menuButton?.addEventListener("click", () => {
        sidebar?.classList.toggle("is-open");
      });

      document.querySelectorAll(".docs-nav a").forEach((link) => {
        link.addEventListener("click", () => sidebar?.classList.remove("is-open"));
      });

      document.querySelectorAll(".prose pre").forEach((pre) => {
        const button = document.createElement("button");
        button.className = "copy-code";
        button.type = "button";
        button.textContent = "Copy";
        button.addEventListener("click", async () => {
          const code = pre.textContent ?? "";
          await navigator.clipboard?.writeText(code);
          button.textContent = "Copied";
          setTimeout(() => {
            button.textContent = "Copy";
          }, 1400);
        });
        pre.append(button);
      });
    </script>
  </body>
</html>
